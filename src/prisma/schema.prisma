generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
  UNKNOWN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum RecordStatus {
  ACTIVE
  FOLLOW_UP
  DISCHARGED
  REFERRED
}

enum StaffRole {
  DOCTOR
  PHYSIOTHERAPIST
  PHARMACIST
  NURSE
  ADMIN
  RECEPTIONIST
}

enum UserRole {
  PATIENT
  STAFF
  ADMIN
}

enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      UserRole @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff     Staff?

  @@map("users")
}

model Staff {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  phone          String?
  role           StaffRole
  specialty      String?
  qualifications String?
  experience     Int?
  bio            String?   @db.Text
  imageUrl       String?
  availableDays  String[]
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  appointments   Appointment[]
  prescriptions  Prescription[]
  records        PatientRecord[]

  @@map("staff")
}

model Patient {
  id               String      @id @default(cuid())
  patientNumber    String      @unique
  firstName        String
  lastName         String
  dateOfBirth      DateTime?
  gender           Gender?
  phone            String
  email            String?
  address          String?     @db.Text
  bloodGroup       BloodGroup  @default(UNKNOWN)
  allergies        String?
  emergencyContact String?
  emergencyPhone   String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  records          PatientRecord[]
  appointments     Appointment[]
  prescriptions    Prescription[]
  vitals           Vital[]

  @@map("patients")
}

model PatientRecord {
  id            String       @id @default(cuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  staffId       String?
  staff         Staff?       @relation(fields: [staffId], references: [id])
  condition     String
  diagnosis     String?      @db.Text
  treatment     String?      @db.Text
  clinicalNotes String?      @db.Text
  status        RecordStatus @default(ACTIVE)
  admissionDate DateTime     @default(now())
  dischargeDate DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  prescriptions Prescription[]

  @@map("patient_records")
}

model Appointment {
  id              String            @id @default(cuid())
  appointmentRef  String            @unique
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  staffId         String?
  staff           Staff?            @relation(fields: [staffId], references: [id])
  service         String
  scheduledDate   DateTime
  scheduledTime   String
  status          AppointmentStatus @default(PENDING)
  notes           String?           @db.Text
  isEmergency     Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("appointments")
}

model Prescription {
  id           String             @id @default(cuid())
  patientId    String
  patient      Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  staffId      String?
  staff        Staff?             @relation(fields: [staffId], references: [id])
  recordId     String?
  record       PatientRecord?     @relation(fields: [recordId], references: [id])
  medication   String
  dosage       String
  frequency    String
  duration     String
  instructions String?            @db.Text
  status       PrescriptionStatus @default(ACTIVE)
  issuedDate   DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@map("prescriptions")
}

model Vital {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  bloodPressure String?
  pulse         Int?
  temperature   Float?
  weight        Float?
  height        Float?
  oxygenSat     Int?
  notes         String?
  recordedAt    DateTime @default(now())

  @@map("vitals")
}

model Testimonial {
  id          String   @id @default(cuid())
  patientName String
  condition   String
  review      String   @db.Text
  rating      Int      @default(5)
  outcome     String?
  location    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("testimonials")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  service   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
